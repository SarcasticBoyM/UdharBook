generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  SHOP_ADMIN
  STAFF
}

enum CustomerStatus {
  ACTIVE
  PENDING
  HIGH_RISK
  CLEARED
}

enum FollowUpStatus {
  PENDING
  CONTACTED
  PAYMENT_PROMISED
  PARTIAL_PAID
  PAID
  NOT_REACHABLE
  WRONG_NUMBER
  COMPLETED
  MISSED
  RESCHEDULED
}

enum FollowUpPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum ChequeStatus {
  COLLECTED
  PENDING_DEPOSIT
  DEPOSITED
  CLEARED
  BOUNCED
  REPLACED
  CANCELLED
}

enum ChequeActivityType {
  CREATED
  STATUS_CHANGED
  DEPOSITED
  CLEARED
  BOUNCED
  REPLACED
  CANCELLED
  NOTE
}

model Shop {
  id                 String             @id @default(cuid())
  shopName           String             @map("name")
  ownerName          String
  email              String?
  gstNumber          String?
  mobile             String?            @map("mobileNumber")
  address            String?
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  users              User[]
  customers          Customer[]
  followUps          FollowUp[]
  payments           PaymentEntry[]
  notes              CustomerNote[]
  activityLogs       ActivityLog[]
  cheques            Cheque[]
  chequeActivities   ChequeActivity[]

  @@index([subscriptionStatus])
  @@index([createdAt])
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(STAFF)
  shopId       String
  shop         Shop       @relation(fields: [shopId], references: [id], onDelete: Restrict)
  disabledAt   DateTime?
  lastLoginAt  DateTime?
  passwordResetRequired Boolean @default(false)
  tempPasswordExpiresAt DateTime?
  createdAt    DateTime   @default(now())
  followUps    FollowUp[]
  statusHistory StatusHistory[]
  notes        CustomerNote[]
  payments     PaymentEntry[]
  activityLogs ActivityLog[]
  passwordResetTokens PasswordResetToken[]
  collectedCheques Cheque[] @relation("ChequeCollectedBy")
  depositedCheques Cheque[] @relation("ChequeDepositedBy")
  chequeActivities ChequeActivity[]

  @@index([shopId])
  @@index([role])
}

model Customer {
  id                 String         @id @default(cuid())
  shopId             String
  shop               Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  partyName          String
  contactNumber      String
  outstandingBalance Float          @default(0)
  lastFollowupDate   DateTime?
  nextFollowupDate   DateTime?
  status             CustomerStatus @default(PENDING)
  notes              String?
  totalCallsMade     Int            @default(0)
  balanceAsOfDate    DateTime       @default(now())
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  followUps          FollowUp[]
  statusHistory      StatusHistory[]
  payments           PaymentEntry[]
  comments           CustomerNote[]
  activityLogs       ActivityLog[]
  cheques            Cheque[]

  @@index([nextFollowupDate])
  @@index([status])
  @@index([outstandingBalance])
  @@index([partyName])
  @@index([createdAt])
  @@index([shopId, partyName])
  @@index([shopId, contactNumber])
  @@index([shopId, nextFollowupDate])
  @@index([shopId, status])
  @@unique([shopId, contactNumber])
}

model FollowUp {
  id               String         @id @default(cuid())
  shopId           String
  shop             Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerId       String
  customer         Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  followupDate     DateTime       @default(now())
  status           FollowUpStatus
  priority         FollowUpPriority @default(MEDIUM)
  notes            String?
  reminderNotes    String?
  customerResponse String?
  nextFollowupDate DateTime?
  scheduledAt      DateTime?
  completedAt      DateTime?
  rescheduledAt    DateTime?
  remindedAt       DateTime?
  actionLoggedAt   DateTime       @default(now())
  queueRank        Int?
  createdById      String
  createdBy        User           @relation(fields: [createdById], references: [id])
  createdAt        DateTime       @default(now())

  @@index([customerId, followupDate])
  @@index([nextFollowupDate])
  @@index([scheduledAt])
  @@index([rescheduledAt])
  @@index([priority])
  @@index([queueRank])
  @@index([shopId, scheduledAt])
  @@index([shopId, status])
}

model StatusHistory {
  id          String          @id @default(cuid())
  customerId  String
  customer    Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  fromStatus  CustomerStatus?
  toStatus    CustomerStatus
  notes       String?
  changedById String
  changedBy   User            @relation(fields: [changedById], references: [id])
  createdAt   DateTime        @default(now())

  @@index([customerId, createdAt])
}

model PaymentEntry {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  amount      Float
  paidAt      DateTime @default(now())
  method      String?
  notes       String?
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([customerId, paidAt])
  @@index([paidAt])
  @@index([shopId, paidAt])
}

model Cheque {
  id                 String       @id @default(cuid())
  shopId             String
  shop               Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerId         String
  customer           Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerCode       String?
  chequeNumber       String
  bankName           String
  branch             String?
  chequeDate         DateTime
  amount             Float
  accountHolderName  String
  collectedById      String
  collectedBy        User         @relation("ChequeCollectedBy", fields: [collectedById], references: [id])
  collectionDateTime DateTime
  collectionNotes    String?
  frontImageUrl      String?
  backImageUrl       String?
  micrCode           String?
  ifscCode           String?
  ocrRawText         String?
  ocrExtractedData   Json?
  ocrConfidence      Float?
  ocrEditedFields    Json?
  depositDateTime    DateTime?
  depositBankAccount String?
  depositSlipUrl     String?
  depositedById      String?
  depositedBy        User?        @relation("ChequeDepositedBy", fields: [depositedById], references: [id])
  status             ChequeStatus @default(COLLECTED)
  bounceReason       String?
  bouncedAt          DateTime?
  clearedAt          DateTime?
  cancelledAt        DateTime?
  replacedByChequeId String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  activities         ChequeActivity[]

  @@unique([shopId, chequeNumber, bankName])
  @@index([shopId, status])
  @@index([shopId, chequeDate])
  @@index([shopId, collectionDateTime])
  @@index([shopId, depositDateTime])
  @@index([customerId, createdAt])
  @@index([collectedById, collectionDateTime])
}

model ChequeActivity {
  id         String             @id @default(cuid())
  shopId     String
  shop       Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  chequeId   String
  cheque     Cheque             @relation(fields: [chequeId], references: [id], onDelete: Cascade)
  userId     String
  user       User               @relation(fields: [userId], references: [id])
  type       ChequeActivityType
  fromStatus ChequeStatus?
  toStatus   ChequeStatus?
  notes      String?
  createdAt  DateTime           @default(now())

  @@index([shopId, createdAt])
  @@index([chequeId, createdAt])
  @@index([userId, createdAt])
}

model CustomerNote {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  note        String
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([customerId, createdAt])
  @@index([shopId, createdAt])
}

model ActivityLog {
  id          String    @id @default(cuid())
  shopId      String?
  shop        Shop?     @relation(fields: [shopId], references: [id], onDelete: SetNull)
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  action      String
  details     String?
  createdAt   DateTime  @default(now())

  @@index([createdAt])
  @@index([shopId, createdAt])
  @@index([userId])
  @@index([customerId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}
