generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  SHOP_ADMIN
  SALES_PERSON
  ACCOUNT_STAFF
  SALES_PERSON_CUM_ACCOUNTS
}

enum OperationalRole {
  SHOP_ADMIN
  ACCOUNTING_STAFF
  FIELD_SALES_PERSON
  CHEQUE_OPERATIONS
  ORDER_MANAGER
  FOLLOWUP_MANAGER
}

enum CustomerStatus {
  ACTIVE
  PENDING
  HIGH_RISK
  CLEARED
}

enum FollowUpStatus {
  PENDING
  CALLBACK
  FOLLOW_UP_REQUIRED
  CONTACTED
  PAYMENT_PROMISED
  PARTIAL_PAID
  PAID
  NOT_REACHABLE
  WRONG_NUMBER
  COMPLETED
  MISSED
  RESCHEDULED
}

enum FollowUpPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum ChequeStatus {
  COLLECTED
  PENDING_DEPOSIT
  DEPOSITED
  CLEARED
  BOUNCED
  REPLACED
  RETURNED_TO_PARTY
  CANCELLED
}

enum ChequeActivityType {
  CREATED
  STATUS_CHANGED
  DEPOSITED
  CLEARED
  BOUNCED
  REPLACED
  CANCELLED
  NOTE
}

enum StaffTrackingStatus {
  ACTIVE
  ON_VISIT
  IDLE
  OFFLINE
}

enum StaffVisitStatus {
  CHECKED_IN
  COMPLETED
  CANCELLED
}

enum AttendanceStatus {
  ACTIVE
  COMPLETED
}

enum OrderStatus {
  ORDER_RECEIVED
  DISPATCHED
  PENDING
  PROCESSING
  DELIVERED
  CANCELLED
}

model Shop {
  id                 String             @id @default(cuid())
  shopName           String             @map("name")
  ownerName          String
  email              String?
  gstNumber          String?
  mobile             String?            @map("mobileNumber")
  address            String?
  city               String?
  businessType       String?
  logoUrl            String?
  onboardingCompleted Boolean           @default(true)
  setupStep          String?
  setupCompletedAt   DateTime?
  recoveryPreferences Json?
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  users              User[]
  customers          Customer[]
  followUps          FollowUp[]
  payments           PaymentEntry[]
  notes              CustomerNote[]
  activityLogs       ActivityLog[]
  cheques            Cheque[]
  chequeActivities   ChequeActivity[]
  chequeDepositAccounts ChequeDepositAccount[]
  staffLocations     StaffLocation[]
  staffVisits        StaffVisit[]
  attendances        Attendance[]
  routeHistories     RouteHistory[]
  visitPhotos        VisitPhoto[]
  supportAccessGrants SupportAccessGrant[]
  orders             Order[]
  userRoleAssignments UserRoleAssignment[]
  orderActivities    OrderActivity[]
  qrVCard            QRVCard?

  @@index([subscriptionStatus])
  @@index([createdAt])
}

model QRVCard {
  id              String   @id @default(cuid())
  shopId          String   @unique
  shop            Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  slug            String   @unique
  businessName    String
  tagline         String?
  gstNumber       String?
  ownerName       String?
  mobile1         String?
  mobile2         String?
  whatsappNumber  String?
  email           String?
  address         String?
  mapUrl          String?
  mapsLink        String?
  website         String?
  instagram       String?
  facebook        String?
  youtube         String?
  logoUrl         String?
  bannerUrl       String?
  category        String?
  aboutBusiness   String?
  categories      String[] @default([])
  socialLinks     Json?
  products        Json?
  galleryImages   Json?
  theme           String   @default("professional-blue")
  isPublic        Boolean  @default(true)
  viewCount       Int      @default(0)
  clickCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  gallery         QRVCardGallery[]
  brands          QRVCardBrand[]
  analytics       QRVCardAnalytics[]

  @@index([shopId])
  @@index([slug])
  @@index([isPublic])
}

model QRVCardGallery {
  id        String   @id @default(cuid())
  cardId    String
  card      QRVCard  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  imageUrl  String
  title     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([cardId])
  @@index([cardId, sortOrder])
}

model QRVCardBrand {
  id        String   @id @default(cuid())
  cardId    String
  card      QRVCard  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  name      String
  logoUrl   String?
  website   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([cardId])
  @@index([cardId, sortOrder])
}

model QRVCardAnalytics {
  id        String   @id @default(cuid())
  cardId    String
  card      QRVCard  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  eventType String
  metadata  Json?
  ipHash    String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([cardId, eventType])
  @@index([cardId, createdAt])
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  mobile       String?
  passwordHash String
  role         UserRole   @default(ACCOUNT_STAFF)
  jobTitle     String?
  shopId       String
  shop         Shop       @relation(fields: [shopId], references: [id], onDelete: Restrict)
  disabledAt   DateTime?
  lastLoginAt  DateTime?
  firstLoginAt DateTime?
  passwordResetRequired Boolean @default(false)
  tempPasswordExpiresAt DateTime?
  createdAt    DateTime   @default(now())
  followUps    FollowUp[]
  statusHistory StatusHistory[]
  notes        CustomerNote[]
  payments     PaymentEntry[]
  activityLogs ActivityLog[]
  passwordResetTokens PasswordResetToken[]
  collectedCheques Cheque[] @relation("ChequeCollectedBy")
  depositedCheques Cheque[] @relation("ChequeDepositedBy")
  receiptUploadedCheques Cheque[] @relation("ChequeReceiptUploadedBy")
  chequeActivities ChequeActivity[]
  staffLocations StaffLocation[]
  staffVisits StaffVisit[]
  attendances Attendance[]
  routeHistories RouteHistory[]
  visitPhotos VisitPhoto[]
  supportAccessRequested SupportAccessGrant[] @relation("SupportAccessRequestedBy")
  supportAccessAssigned SupportAccessGrant[] @relation("SupportAccessSuperAdmin")
  ordersCreated Order[] @relation("OrderCreatedBy")
  orderActivities OrderActivity[]
  roleAssignments UserRoleAssignment[] @relation("UserRoleAssignments")
  roleAssignmentsCreated UserRoleAssignment[] @relation("UserRoleAssignmentsCreatedBy")

  @@index([shopId])
  @@index([role])
}

model UserRoleAssignment {
  id          String          @id @default(cuid())
  shopId      String
  shop        Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  userId      String
  user        User            @relation("UserRoleAssignments", fields: [userId], references: [id], onDelete: Cascade)
  role        OperationalRole
  assignedById String?
  assignedBy   User?          @relation("UserRoleAssignmentsCreatedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  createdAt   DateTime        @default(now())

  @@unique([userId, role])
  @@index([shopId, role])
  @@index([shopId, userId])
}

model Customer {
  id                 String         @id @default(cuid())
  shopId             String
  shop               Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  partyName          String
  contactNumber      String
  batchTag           String?
  outstandingBalance Float          @default(0)
  lastFollowupDate   DateTime?
  nextFollowupDate   DateTime?
  status             CustomerStatus @default(PENDING)
  notes              String?
  totalCallsMade     Int            @default(0)
  balanceAsOfDate    DateTime       @default(now())
  isArchived         Boolean        @default(false)
  archivedAt         DateTime?
  archivedById       String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  followUps          FollowUp[]
  statusHistory      StatusHistory[]
  payments           PaymentEntry[]
  comments           CustomerNote[]
  activityLogs       ActivityLog[]
  cheques            Cheque[]
  latitude           Float?
  longitude          Float?
  geoAddress         String?
  staffVisits        StaffVisit[]
  orders             Order[]

  @@index([nextFollowupDate])
  @@index([status])
  @@index([outstandingBalance])
  @@index([partyName])
  @@index([createdAt])
  @@index([shopId, partyName])
  @@index([shopId, batchTag])
  @@index([shopId, batchTag, partyName])
  @@index([shopId, batchTag, contactNumber])
  @@index([shopId, contactNumber])
  @@index([shopId, nextFollowupDate])
  @@index([shopId, outstandingBalance])
  @@index([shopId, outstandingBalance, nextFollowupDate])
  @@index([shopId, lastFollowupDate])
  @@index([shopId, updatedAt])
  @@index([shopId, status])
  @@index([shopId, isArchived])
}

model StaffLocation {
  id        String              @id @default(cuid())
  shopId    String
  shop      Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)
  staffId   String
  staff     User                @relation(fields: [staffId], references: [id], onDelete: Cascade)
  latitude  Float
  longitude Float
  accuracy  Float?
  status    StaffTrackingStatus @default(ACTIVE)
  battery   Float?
  source    String?
  createdAt DateTime            @default(now())

  @@index([shopId, createdAt])
  @@index([staffId, createdAt])
  @@index([shopId, staffId, createdAt])
  @@index([shopId, status])
}

model Attendance {
  id            String           @id @default(cuid())
  shopId        String
  shop          Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  staffId       String
  staff         User             @relation(fields: [staffId], references: [id], onDelete: Cascade)
  workDate      DateTime
  startedAt     DateTime         @default(now())
  endedAt       DateTime?
  activeMinutes Int              @default(0)
  idleMinutes   Int              @default(0)
  travelKm      Float            @default(0)
  status        AttendanceStatus @default(ACTIVE)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([staffId, workDate])
  @@index([shopId, workDate])
  @@index([shopId, status])
}

model StaffVisit {
  id              String           @id @default(cuid())
  shopId          String
  shop            Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  staffId         String
  staff           User             @relation(fields: [staffId], references: [id], onDelete: Cascade)
  customerId      String
  customer        Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  status          StaffVisitStatus @default(CHECKED_IN)
  checkInAt       DateTime         @default(now())
  checkOutAt      DateTime?
  checkInLat      Float
  checkInLng      Float
  checkOutLat     Float?
  checkOutLng     Float?
  accuracy        Float?
  distanceMeters  Float?
  verified        Boolean          @default(false)
  outsideWarning  Boolean          @default(false)
  notes           String?
  result          String?
  visitType       String           @default("Follow-up")
  outcome         String?
  nextAction      String?
  nextVisitDate   DateTime?
  orderAmount     Float?
  orderQuantity   Float?
  orderExpectedDelivery DateTime?
  orderProductCategory String?
  orderPriority   String?
  paymentMode     String?
  paymentReference String?
  paymentBankName String?
  paymentScreenshotUrl String?
  leadArea        String?
  leadContactPerson String?
  visitMetadata   Json?
  recoveryAmount  Float            @default(0)
  travelKm        Float            @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  photos          VisitPhoto[]
  cheques         Cheque[]
  orders          Order[]

  @@index([shopId, checkInAt])
  @@index([staffId, checkInAt])
  @@index([customerId, checkInAt])
  @@index([shopId, status])
  @@index([shopId, visitType])
  @@index([shopId, status, visitType])
  @@index([shopId, nextVisitDate])
  @@index([shopId, staffId, createdAt])
  @@index([shopId, staffId, status, checkInAt])
  @@index([shopId, customerId, checkInAt])
}

model Order {
  id                    String      @id @default(cuid())
  shopId                String
  shop                  Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerId            String
  customer              Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdById           String
  createdBy             User        @relation("OrderCreatedBy", fields: [createdById], references: [id])
  staffVisitId          String?
  staffVisit            StaffVisit? @relation(fields: [staffVisitId], references: [id], onDelete: SetNull)
  orderDetails          String
  preferredDeliveryDate DateTime?
  priority              String      @default("Normal")
  status                OrderStatus @default(ORDER_RECEIVED)
  sourceModule          String      @default("FIELD_VISIT")
  visitSource           String?
  deliveredAt           DateTime?
  cancelledAt           DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  activities            OrderActivity[]

  @@unique([shopId, staffVisitId])
  @@index([shopId, status, priority])
  @@index([shopId, preferredDeliveryDate])
  @@index([shopId, createdAt])
  @@index([shopId, createdById, createdAt])
  @@index([customerId, createdAt])
}

model OrderActivity {
  id             String       @id @default(cuid())
  shopId         String
  shop           Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  orderId        String
  order          Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  action         String
  previousStatus OrderStatus?
  newStatus      OrderStatus?
  notes          String?
  createdAt      DateTime     @default(now())

  @@index([shopId, createdAt])
  @@index([orderId, createdAt])
  @@index([userId, createdAt])
}

model VisitPhoto {
  id          String     @id @default(cuid())
  shopId      String
  shop        Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  visitId     String
  visit       StaffVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy  User       @relation(fields: [uploadedById], references: [id])
  url         String
  fileType    String?
  notes       String?
  createdAt   DateTime   @default(now())

  @@index([shopId, createdAt])
  @@index([visitId])
}

model RouteHistory {
  id             String   @id @default(cuid())
  shopId         String
  shop           Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  staffId        String
  staff          User     @relation(fields: [staffId], references: [id], onDelete: Cascade)
  routeDate      DateTime
  totalKm        Float    @default(0)
  totalVisits    Int      @default(0)
  productiveHours Float   @default(0)
  startedAt      DateTime?
  endedAt        DateTime?
  path           Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([staffId, routeDate])
  @@index([shopId, routeDate])
}

model FollowUp {
  id               String         @id @default(cuid())
  shopId           String
  shop             Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerId       String
  customer         Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  followupDate     DateTime       @default(now())
  status           FollowUpStatus
  priority         FollowUpPriority @default(MEDIUM)
  notes            String?
  reminderNotes    String?
  customerResponse String?
  sourceModule     String         @default("TODAY_FOLLOWUPS")
  followUpType     String?
  summary          String?
  detailedNotes    String?
  recoveryAmount   Float?
  paymentStatus    String?
  chequeId         String?
  chequeStatus     String?
  promiseDate      DateTime?
  visitId          String?
  activitySource   String?
  metadata         Json?
  nextFollowupDate DateTime?
  nextFollowUpDateTime DateTime?
  scheduledAt      DateTime?
  completedAt      DateTime?
  rescheduledAt    DateTime?
  remindedAt       DateTime?
  reminderEnabled  Boolean        @default(false)
  manualReminder   Boolean        @default(false)
  reminderSentAt   DateTime?
  actionLoggedAt   DateTime       @default(now())
  queueRank        Int?
  createdById      String
  createdBy        User           @relation(fields: [createdById], references: [id])
  createdAt        DateTime       @default(now())

  @@index([customerId, followupDate])
  @@index([nextFollowupDate])
  @@index([scheduledAt])
  @@index([nextFollowUpDateTime])
  @@index([shopId, manualReminder, reminderEnabled, reminderSentAt])
  @@index([shopId, manualReminder, reminderEnabled, reminderSentAt, nextFollowUpDateTime], map: "FollowUp_manual_reminder_due_idx")
  @@index([shopId, createdById, followupDate])
  @@index([shopId, customerId, followupDate])
  @@index([shopId, status, followupDate])
  @@index([rescheduledAt])
  @@index([priority])
  @@index([queueRank])
  @@index([shopId, scheduledAt])
  @@index([shopId, status])
  @@index([shopId, sourceModule])
  @@index([shopId, activitySource])
  @@index([chequeId])
  @@index([visitId])
  @@index([promiseDate])
}

model StatusHistory {
  id          String          @id @default(cuid())
  customerId  String
  customer    Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  fromStatus  CustomerStatus?
  toStatus    CustomerStatus
  notes       String?
  changedById String
  changedBy   User            @relation(fields: [changedById], references: [id])
  createdAt   DateTime        @default(now())

  @@index([customerId, createdAt])
  @@index([changedById, createdAt])
}

model PaymentEntry {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  amount      Float
  paidAt      DateTime @default(now())
  method      String?
  notes       String?
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([customerId, paidAt])
  @@index([paidAt])
  @@index([shopId, paidAt])
}

model Cheque {
  id                 String       @id @default(cuid())
  shopId             String
  shop               Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerId         String
  customer           Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerCode       String?
  chequeNumber       String
  bankName           String
  branch             String?
  chequeDate         DateTime
  amount             Float
  accountHolderName  String
  collectedById      String
  collectedBy        User         @relation("ChequeCollectedBy", fields: [collectedById], references: [id])
  staffVisitId       String?
  staffVisit         StaffVisit?  @relation(fields: [staffVisitId], references: [id], onDelete: SetNull)
  collectionLatitude Float?
  collectionLongitude Float?
  collectionAccuracy Float?
  collectionDateTime DateTime
  collectionNotes    String?
  frontImageUrl      String?
  backImageUrl       String?
  micrCode           String?
  ifscCode           String?
  ocrRawText         String?
  ocrExtractedData   Json?
  ocrConfidence      Float?
  ocrEditedFields    Json?
  depositDateTime    DateTime?
  depositBankAccount String?
  depositSlipUrl     String?
  depositReceiptUrl  String?
  depositReceiptType String?
  depositReceiptUploadedAt DateTime?
  depositReceiptUploadedById String?
  depositReceiptUploadedBy User? @relation("ChequeReceiptUploadedBy", fields: [depositReceiptUploadedById], references: [id])
  depositedById      String?
  depositedBy        User?        @relation("ChequeDepositedBy", fields: [depositedById], references: [id])
  depositedAccountId String?
  depositedAccount   ChequeDepositAccount? @relation(fields: [depositedAccountId], references: [id])
  status             ChequeStatus @default(COLLECTED)
  bounceReason       String?
  bouncedAt          DateTime?
  clearedAt          DateTime?
  cancelledAt        DateTime?
  replacedByChequeId String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  activities         ChequeActivity[]

  @@unique([shopId, chequeNumber, bankName])
  @@index([shopId, status])
  @@index([shopId, chequeDate])
  @@index([shopId, collectionDateTime])
  @@index([shopId, depositDateTime])
  @@index([shopId, depositedAccountId])
  @@index([staffVisitId])
  @@index([depositReceiptUploadedById])
  @@index([customerId, createdAt])
  @@index([shopId, status, amount])
  @@index([shopId, status, collectionDateTime])
  @@index([shopId, status, depositDateTime])
  @@index([shopId, depositedAccountId, status])
  @@index([shopId, collectedById, collectionDateTime])
  @@index([collectedById, collectionDateTime])
}

model ChequeDepositAccount {
  id             String   @id @default(cuid())
  shopId         String
  shop           Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  accountName    String
  bankName       String
  lastFourDigits String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  cheques        Cheque[]

  @@index([shopId, isActive])
  @@index([shopId, bankName])
}

model ChequeActivity {
  id         String             @id @default(cuid())
  shopId     String
  shop       Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  chequeId   String
  cheque     Cheque             @relation(fields: [chequeId], references: [id], onDelete: Cascade)
  userId     String
  user       User               @relation(fields: [userId], references: [id])
  type       ChequeActivityType
  fromStatus ChequeStatus?
  toStatus   ChequeStatus?
  notes      String?
  createdAt  DateTime           @default(now())

  @@index([shopId, createdAt])
  @@index([chequeId, createdAt])
  @@index([userId, createdAt])
}

model CustomerNote {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  note        String
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([customerId, createdAt])
  @@index([shopId, createdAt])
}

model ActivityLog {
  id          String    @id @default(cuid())
  shopId      String?
  shop        Shop?     @relation(fields: [shopId], references: [id], onDelete: SetNull)
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  action      String
  details     String?
  createdAt   DateTime  @default(now())

  @@index([createdAt])
  @@index([shopId, createdAt])
  @@index([shopId, action, createdAt])
  @@index([userId])
  @@index([customerId])
}

model SupportAccessGrant {
  id             String    @id @default(cuid())
  shopId         String
  shop           Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  requestedById  String
  requestedBy    User      @relation("SupportAccessRequestedBy", fields: [requestedById], references: [id], onDelete: Cascade)
  superAdminId   String?
  superAdmin     User?     @relation("SupportAccessSuperAdmin", fields: [superAdminId], references: [id], onDelete: SetNull)
  reason         String
  status         String    @default("ACTIVE")
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([shopId, status, expiresAt])
  @@index([superAdminId, status, expiresAt])
  @@index([requestedById, createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}
